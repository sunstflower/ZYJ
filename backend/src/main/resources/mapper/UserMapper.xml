<mapper namespace="com.jsa.dao.UserMapper">

    <!-- 字段与实体字段映射（驼峰自动映射已开启，列名按需补充） -->
    <resultMap id="UserMap" type="com.jsa.entity.User">
        <id property="id" column="id"/>
